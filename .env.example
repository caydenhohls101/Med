# ============================================================
# MediBook SA — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ---- Supabase (Required) ------------------------------------
# Found in: Supabase Dashboard → Settings → API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose to browser, NEVER commit
# Used only in server-side code (lib/supabase/service.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct Postgres connection string (for Drizzle migrations)
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL for serverless (port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ---- Resend (Required for email) ---------------------------
# Sign up at resend.com, verify your domain, get your API key
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@yourdomain.co.za

# ---- App URL -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Sentry (Optional — required for production) -----------
# Sign up at sentry.io, create a Next.js project
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=sntrys_...

# ---- PostHog Analytics (Optional) -------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=phx_...

# ---- Cloudflare Turnstile (Optional — required for production booking form) --
# Sign up at dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# ---- Build flags -------------------------------------------
# Set to 1 to skip env validation during CI builds (use carefully)
# SKIP_ENV_VALIDATION=1
